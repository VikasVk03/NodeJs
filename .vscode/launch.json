{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program tsc",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/TypeScript/ts/index.ts",
      "preLaunchTask": "tsc: build - TypeScript/tsconfig.json", // run a task before launch, here compile before debug, it will execute the configuration tsconfig.json file
      "outFiles": ["${workspaceFolder}/**/*.js"]
    }
  ]
}

// in run and debug tab, watch use to track change in value of variablesm, ex: click on + and type name of varible
